	$(MAKE) $(MAKESILENT) -f CMakeFiles/main.dir/build.make CMakeFiles/main.dir/src/wspolna.cpp.o
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_operacji.dir/build.make CMakeFiles/test_operacji.dir/src/wspolna.cpp.o
.PHONY : src/wspolna.cpp.o

src/wspolna.i: src/wspolna.cpp.i
.PHONY : src/wspolna.i

